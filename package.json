{
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter @r2/trellis build",
    "test": "pnpm --filter @r2/trellis test",
    "lint": "pnpm --filter @r2/trellis lint",
    "typecheck": "pnpm --filter @r2/trellis typecheck",
    "release": "pnpm --filter @r2/trellis release",
    "release:minor": "pnpm --filter @r2/trellis release:minor",
    "release:beta": "pnpm --filter @r2/trellis release:beta",
    "release:rc": "pnpm --filter @r2/trellis release:rc",
    "update-submodule": "git submodule update --remote"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
